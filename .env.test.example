# Copy to .env.test.local (already gitignored via *.local) and fill in real
# values. NEVER commit the service-role key — it bypasses RLS entirely.

# Same project as VITE_SUPABASE_URL in .env — there is no separate staging
# project yet, so e2e tests run against this one. Test fixtures (a
# dedicated owner account + business + branch + service) are created and
# torn down per-run via the service-role key, so they never touch real data.
SUPABASE_SERVICE_ROLE_KEY=

# The password set via: npx supabase secrets set ADMIN_DASHBOARD_PASSWORD=...
# Needed so admin.spec.ts can actually log into /admin.
ADMIN_DASHBOARD_PASSWORD=

# Optional — defaults to http://localhost:5173 (vite dev server)
# E2E_BASE_URL=http://localhost:5173
